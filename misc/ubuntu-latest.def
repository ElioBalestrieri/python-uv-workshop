Bootstrap: docker
From: harbor.uni-muenster.de/proxy-docker/ubuntu

%help 
Container image for didactic purpose

%labels
    Maintainer Universität Münster, CIT
    Version v1.0

%post
	apt update --quiet \
	&& DEBIAN_FRONTEND=noninteractive apt install --yes --quiet \
		build-essential \
		cmake \
		git \
		wget \
		curl \
		bc \
		tzdata \
		acl \
	&& rm -rf /var/lib/apt/lists/* \
	&& apt-get autoremove -y \
	&& apt-get clean \
	&& curl https://getmic.ro | bash \
	&& mv micro /usr/bin 
	
%environment
	export TERM="tmux-256color"
	NAME_COLOR="\[\033[38;5;42m\]"
	HOST_COLOR="\[\033[38;5;245m\]"
	RESET="\[\033[0m\]"
	export PS1="${NAME_COLOR}\u$RESET@${HOST_COLOR}uv-workshop: $RESET\w \$ "
	alias ls="ls --color"
	alias l="ls -lh"
	
